*/1 * * * * run-one sleep 20; python /app/manage.py waiting_queue_rotate 5 10 >> /app/logs/waiting_queue_rotate.log 2>&1
*/1 * * * * run-one sleep 20; python /app/manage.py waiting_queue_rotate 10 15 >> /app/logs/waiting_queue_rotate.log 2>&1
*/1 * * * * run-one sleep 20; python /app/manage.py waiting_queue_rotate 15 20 >> /app/logs/waiting_queue_rotate.log 2>&1
*/1 * * * * run-one sleep 40; python /app/manage.py waiting_queue_rotate 1 5 >> /app/logs/waiting_queue_rotate.log 2>&1
*/1 * * * * run-one sleep 40; python /app/manage.py waiting_queue_rotate 5 10 >> /app/logs/waiting_queue_rotate.log 2>&1
