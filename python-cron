# Clean Recently Deleted
*/5 * * * * run-one python /app/manage.py clean_recently_deleted  >> /app/logs/clean_recently_deleted.log 2>&1

# Purge idle sessions
*/1 * * * * run-one python /app/manage.py queue_manager_delete_idle_sessions  >> /app/logs/queue_manager_delete_idle_sessions.log 2>&1

